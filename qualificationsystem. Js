const { EmbedBuilder } = require('discord.js');

module.exports = {
    async checkAndPromote(client, db, config) {
        const week = this.getWeekNumber(new Date()) - 1;
        
        db.all(`SELECT * FROM weekly_scores 
                WHERE week = ? AND wins >= 15 AND top3Count >= 5`, [week], async (err, qualifiedTeams) => {
            
            if (!qualifiedTeams || qualifiedTeams.length === 0) return;
            
            const channel = client.channels.cache.get(config.channels.qualifier);
            if (!channel) return;
            
            const t2Role = client.guilds.cache.get(config.guildId)?.roles.cache.get(config.roles.t2Qualified);
            
            for (const team of qualifiedTeams) {
                const alreadyQualified = await this.isAlreadyQualified(team.teamName, db);
                if (alreadyQualified) continue;
                
                db.run(`INSERT INTO qualified_teams (teamName, players, qualificationDate, roleAssigned) 
                        VALUES (?, ?, ?, ?)`,
                    [team.teamName, team.players, Date.now(), 1]);
                
                const playerIds = team.players.split(',').map(p => p.replace(/[<@>]/g, '').trim());
                for (const playerId of playerIds) {
                    const member = await client.guilds.cache.get(config.guildId)?.members.fetch(playerId).catch(() => null);
                    if (member && t2Role) {
                        await member.roles.add(t2Role);
                    }
                }
                
                const embed = new EmbedBuilder()
                    .setTitle('🏆 **T2 QUALIFICATION ACHIEVED!** 🏆')
                    .setDescription(`
## ✨ **CONGRATULATIONS!** ✨

### 🎉 **${team.teamName}** has qualified for **T2 Tournament!**

### 📊 **Your Performance:**
• ✅ **${team.wins}** Wins (Target: 15)
• 🥉 **${team.top3Count}** Top 3 Finishes (Target: 5)
• ⭐ **${team.totalScore}** Total Score

### 🚀 **Next Steps:**
1️⃣ Check T2 category for schedule
2️⃣ Prepare for higher competition
                    `)
                    .setColor(0xFFA500);
                
                await channel.send({ embeds: [embed] });
            }
        });
    },
    
    isAlreadyQualified(teamName, db) {
        return new Promise((resolve) => {
            db.get(`SELECT * FROM qualified_teams WHERE teamName = ?`, [teamName], (err, row) => {
                resolve(!!row);
            });
        });
    },
    
    getWeekNumber(date) {
        const startDate = new Date(date.getFullYear(), 0, 1);
        const days = Math.floor((date - startDate) / (24 * 60 * 60 * 1000));
        return Math.ceil(days / 7);
    }
};
